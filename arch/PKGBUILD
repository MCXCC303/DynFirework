# Maintainer: MCXCC <mcxcc@example.com>
# Contributor: DynFirework contributors

pkgname=dynfirework-git
_pkgname=dynfirework
pkgver=1.3.0.r67.gafeef83
pkgrel=1
pkgdesc="Minecraft 粒子烟花设计工具 - 基于 PySide6，生成 .mcfunction 数据包"
arch=('any')
url="https://github.com/MCXCC303/DynFirework"
license=('GPL-3.0-only')
depends=('python' 'pyside6' 'python-numpy' 'python-scipy' 'python-soundfile' 'python-pillow' 'qt6ct')
makedepends=('python-build' 'python-installer' 'python-setuptools' 'python-wheel' 'git')
provides=("$_pkgname")
conflicts=("$_pkgname")
source=("$_pkgname::git+file:///home/thf/Programme/Gits/DynFirework-v1.3.git")
sha256sums=('SKIP')

pkgver() {
	cd "$srcdir/$_pkgname"
	local _rev _hash
	_rev=$(git rev-list --count HEAD)
	_hash=$(git rev-parse --short HEAD)
	printf "%s.r%s.g%s" "$(grep -Po 'version\s*=\s*"\K[^"]*' pyproject.toml 2>/dev/null || echo '1.3')" "$_rev" "$_hash"
}

build() {
	cd "$srcdir/$_pkgname"
	python -m build --wheel --no-isolation
}

package() {
	cd "$srcdir/$_pkgname"
	python -m installer --destdir="$pkgdir" dist/*.whl

	install -Dm644 "${srcdir}/$_pkgname/arch/${_pkgname}.desktop" \
		"${pkgdir}/usr/share/applications/${_pkgname}.desktop"
}
